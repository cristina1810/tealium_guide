# OpenAI API Key
# Obtén tu clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-YOUR-API-KEY-HERE

# ID del Assistant de OpenAI
# Obtén el ID en https://platform.openai.com/assistants
MAIN_AGENT_ID=asst_YOUR-ASSISTANT-ID-HERE

# Puerto del servidor (solo para desarrollo local)
PORT=3001

# Entorno
NODE_ENV=development
